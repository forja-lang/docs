---
export interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Forja</title>
    <meta name="description" content={description || "Documentación del lenguaje de programación Forja (fa)"} />
    <link rel="icon" type="image/x-icon" href="/docs/favicon.ico">
    <link rel="shortcut icon" type="image/x-icon" href="/docs/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style is:global>
      /* ===== RESET & BASE ===== */
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --bg: #241716;
        --bg-card: #2a1a18;
        --bg-hover: #33201d;
        --bg-elevated: #3a2522;
        --border: #3d2824;
        --border-glow: #4a302c;
        --text: #edf2f7;
        --text-dim: #94a3b8;
        --text-muted: #5b6a84;

        --fuego: #ed452c;
        --fuego-glow: #d63a22;
        --fuego-light: #f06a4f;
        --fuego-dark: #c4311a;
        --fuego-bg: rgba(237, 69, 44, 0.08);

        --acero: #6366f1;
        --acero-glow: #4f46e5;
        --acero-light: #818cf8;

        --verde: #10b981;
        --rosa: #ec4899;
        --cian: #06b6d4;
        --rojo: #ef4444;

        --sidebar-w: 280px;
        --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text);
        line-height: 1.8;
        display: flex;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

      /* ===== SIDEBAR ===== */
      .sidebar {
        width: var(--sidebar-w);
        min-width: var(--sidebar-w);
        background: linear-gradient(180deg, var(--bg-card) 0%, #1f1311 100%);
        border-right: 1px solid var(--border);
        height: 100vh;
        position: sticky;
        top: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        z-index: 10;
      }

      .sidebar::after {
        content: '';
        position: absolute;
        top: 0;
        right: -1px;
        width: 1px;
        height: 100%;
        background: linear-gradient(180deg, transparent, var(--fuego), transparent);
        opacity: 0.15;
      }

      .sidebar-header {
        padding: 24px 20px 16px;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
        position: relative;
      }

      .sidebar-header .logo {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        margin-bottom: 4px;
      }

      .sidebar-header .logo-icon {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, var(--fuego), var(--fuego-dark));
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: #fff;
        font-weight: 800;
        box-shadow: 0 4px 16px rgba(245, 158, 11, 0.25);
        position: relative;
        overflow: hidden;
      }

      .sidebar-header .logo-icon::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.12));
        border-radius: 10px;
      }

      .sidebar-header .logo-text {
        font-size: 1.35rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--fuego-light), var(--fuego));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.5px;
      }

      .sidebar-header .logo-sub {
        font-size: 0.7rem;
        color: var(--text-muted);
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-left: 50px;
      }

      .sidebar-nav {
        flex: 1;
        overflow-y: auto;
        padding: 8px 0 24px;
        scrollbar-width: thin;
      }

      .sidebar-nav .section-title {
        padding: 20px 20px 4px 20px;
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--text-muted);
        font-weight: 700;
      }

      .sidebar-nav a {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 20px 6px 20px;
        color: var(--text-dim);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 400;
        transition: all 0.18s ease;
        border-left: 2px solid transparent;
        position: relative;
      }

      .sidebar-nav a:hover {
        color: var(--text);
        background: var(--bg-hover);
        border-left-color: var(--fuego);
      }

      .sidebar-nav a.active {
        color: var(--fuego-light);
        background: var(--fuego-bg);
        border-left-color: var(--fuego);
        font-weight: 500;
      }

      .sidebar-nav a.sub { padding-left: 36px; font-size: 0.82rem; }

      .sidebar-nav a .nav-dot {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--text-muted);
        flex-shrink: 0;
        opacity: 0.4;
      }

      .sidebar-nav a:hover .nav-dot { opacity: 1; background: var(--fuego); }

      /* ===== MAIN ===== */
      .main {
        flex: 1;
        padding: 0;
        max-width: 100%;
        min-width: 0;
      }

      .main-inner {
        max-width: 880px;
        margin: 0 auto;
        padding: 48px 56px 80px;
      }

      @media (max-width: 1100px) {
        .sidebar { width: 240px; min-width: 240px; }
        .main-inner { padding: 32px 32px 60px; }
      }

      @media (max-width: 768px) {
        body { flex-direction: column; }
        .sidebar {
          width: 100%;
          min-width: auto;
          height: auto;
          max-height: 50vh;
          position: relative;
          border-right: none;
          border-bottom: 1px solid var(--border);
        }
        .sidebar::after { display: none; }
        .main-inner { padding: 24px 20px 60px; }
      }

      /* ===== TYPOGRAPHY ===== */
      h1 {
        font-size: 2.6rem;
        font-weight: 800;
        margin-bottom: 16px;
        letter-spacing: -0.8px;
        line-height: 1.15;
        background: linear-gradient(135deg, var(--text) 40%, var(--fuego-light));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      h2 {
        font-size: 1.55rem;
        font-weight: 700;
        margin-top: 48px;
        margin-bottom: 12px;
        letter-spacing: -0.3px;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      h2::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(to right, var(--border), transparent);
      }

      h3 {
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: 32px;
        margin-bottom: 8px;
        color: var(--text);
      }

      p { margin-bottom: 16px; color: var(--text-dim); font-size: 0.95rem; }

      a { color: var(--fuego-light); text-decoration: none; font-weight: 500; transition: color 0.15s; }
      a:hover { color: var(--fuego); text-decoration: underline; }

      ul, ol { margin-bottom: 20px; padding-left: 24px; color: var(--text-dim); }
      li { margin-bottom: 6px; }

      strong { color: var(--text); font-weight: 600; }

      /* ===== CODE BLOCKS ===== */
      .code-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 16px;
        background: linear-gradient(135deg, #0a0d14, #0e111a);
        border: 1px solid var(--border);
        border-bottom: none;
        border-radius: 10px 10px 0 0;
        font-size: 0.72rem;
        color: var(--text-muted);
        font-family: var(--font-mono);
        position: relative;
      }

      .code-header::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--fuego), transparent);
        opacity: 0.15;
      }

      .code-header + pre {
        border-radius: 0 0 10px 10px;
        border-top: none;
        margin-top: 0;
      }

      pre {
        background: linear-gradient(135deg, #0b0e16, #0f131e);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 18px 22px;
        overflow-x: auto;
        margin-bottom: 24px;
        font-family: var(--font-mono);
        font-size: 0.82rem;
        line-height: 1.65;
        box-shadow: 0 4px 24px rgba(0,0,0,0.4), inset 0 1px 0 rgba(245, 158, 11, 0.03);
        position: relative;
      }

      pre::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--fuego), transparent);
        opacity: 0.2;
        border-radius: 10px 10px 0 0;
      }

      code {
        font-family: var(--font-mono);
        font-size: 0.85em;
        background: var(--fuego-bg);
        padding: 2px 7px;
        border-radius: 5px;
        color: var(--fuego-light);
        font-weight: 500;
      }

      pre code {
        background: none;
        padding: 0;
        border-radius: 0;
        color: #e2e8f0;
        font-weight: 400;
      }

      /* ===== PALETA DE COLORES FORJA =====
       * Coherente entre: VS Code extension, CLI, playground, docs
       * .kw  → keywords       #f59e0b (fuego/amber)
       * .fn  → builtins       #10b981 (verde/emerald)
       * .ty  → tipos          #06b6d4 (cian/cyan)
       * .st  → strings        #fbbf24 (gold/amber claro)
       * .co  → comentarios    #5b6a84 (gris azulado)
       * .op  → operadores     #ec4899 (rosa/pink)
       * .nu  → números        #818cf8 (acero/indigo)
       */
      .kw { color: var(--fuego-light); font-weight: 500; }
      .fn { color: var(--verde); }
      .ty { color: var(--cian); }
      .st { color: #fbbf24; }
      .co { color: var(--text-muted); font-style: italic; }
      .op { color: var(--rosa); }
      .nu { color: var(--acero-light); }

      /* ===== INFO BOXES ===== */
      .info, .warning, .tip {
        padding: 14px 18px;
        border-radius: 10px;
        margin-bottom: 24px;
        font-size: 0.9rem;
        position: relative;
        border: 1px solid transparent;
        overflow: hidden;
      }

      .info::before, .warning::before, .tip::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        border-radius: 10px 0 0 10px;
      }

      .info {
        background: rgba(99, 102, 241, 0.06);
        border-color: rgba(99, 102, 241, 0.15);
        color: #c7d2fe;
      }
      .info::before { background: var(--acero); }
      .info strong { color: var(--acero-light); }

      .warning {
        background: rgba(245, 158, 11, 0.06);
        border-color: rgba(245, 158, 11, 0.15);
        color: #fde68a;
      }
      .warning::before { background: var(--fuego); }
      .warning strong { color: var(--fuego-light); }

      .tip {
        background: rgba(16, 185, 129, 0.06);
        border-color: rgba(16, 185, 129, 0.15);
        color: #a7f3d0;
      }
      .tip::before { background: var(--verde); }
      .tip strong { color: var(--verde); }

      /* ===== TABLES ===== */
      table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-bottom: 24px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid var(--border);
      }

      th, td {
        padding: 10px 16px;
        text-align: left;
        font-size: 0.875rem;
        border-bottom: 1px solid var(--border);
      }

      th {
        background: var(--bg-card);
        font-weight: 600;
        color: var(--text);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      td { color: var(--text-dim); border-right: 1px solid var(--border); }
      td:last-child { border-right: none; }
      tr:last-child td { border-bottom: none; }
      tr:hover td { background: var(--bg-hover); }

      /* ===== TAG ===== */
      .tag {
        display: inline-block;
        padding: 1px 8px;
        border-radius: 4px;
        font-size: 0.72rem;
        font-weight: 600;
        font-family: var(--font-mono);
      }
      .tag.kw { background: var(--fuego-bg); color: var(--fuego-light); }
      .tag.ty { background: rgba(6, 182, 212, 0.12); color: var(--cian); }
      .tag.fn { background: rgba(16, 185, 129, 0.12); color: var(--verde); }
      .tag.st { background: rgba(251, 191, 36, 0.12); color: var(--fuego-light); }

      /* ===== HERO SECTION ===== */
      .hero {
        margin-bottom: 40px;
        position: relative;
      }

      .hero::before {
        content: '';
        position: absolute;
        top: -40px;
        left: -40px;
        right: -40px;
        bottom: -20px;
        background: radial-gradient(ellipse 600px 300px at 50% 0%, rgba(245, 158, 11, 0.04), transparent 70%);
        pointer-events: none;
      }

      .hero h1 { font-size: 3.2rem; margin-bottom: 8px; }
      .hero .subtitle { font-size: 1.1rem; color: var(--text-dim); margin-bottom: 6px; }
      .hero .badge-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 18px;
      }

      .hero .badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 14px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 500;
        border: 1px solid var(--border);
        background: var(--bg-card);
        color: var(--text-dim);
        transition: all 0.2s;
      }

      .hero .badge:hover {
        border-color: var(--fuego);
        color: var(--fuego-light);
        background: var(--fuego-bg);
      }

      .hero .badge.dot {
        border-color: transparent;
        background: var(--fuego-bg);
        color: var(--fuego-light);
      }

      /* ===== FEATURE GRID ===== */
      .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 12px;
        margin-bottom: 32px;
      }

      .feature-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 18px 20px;
        transition: all 0.25s ease;
        position: relative;
        overflow: hidden;
      }

      .feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(to right, transparent, var(--fuego), transparent);
        opacity: 0;
        transition: opacity 0.25s;
      }

      .feature-card:hover {
        border-color: var(--fuego);
        background: var(--bg-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.25), 0 0 0 1px rgba(245, 158, 11, 0.05);
      }

      .feature-card:hover::before { opacity: 0.4; }

      .feature-card .icon { font-size: 1.4rem; margin-bottom: 8px; display: block; }
      .feature-card h4 { font-size: 0.92rem; font-weight: 600; margin-bottom: 4px; color: var(--text); }
      .feature-card p { font-size: 0.82rem; color: var(--text-dim); margin: 0; }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 600px) {
        h1 { font-size: 1.8rem; }
        h2 { font-size: 1.25rem; }
        .hero h1 { font-size: 2rem; }
        .hero .subtitle { font-size: 0.95rem; }
        .feature-grid { grid-template-columns: 1fr; }
        pre { font-size: 0.75rem; padding: 14px 16px; }
        table { font-size: 0.75rem; }
        th, td { padding: 8px 10px; }
      }

      /* ===== ANIMATIONS ===== */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .main-inner > * {
        animation: fadeInUp 0.4s ease forwards;
      }

      .main-inner > *:nth-child(2) { animation-delay: 0.05s; }
      .main-inner > *:nth-child(3) { animation-delay: 0.1s; }
      .main-inner > *:nth-child(4) { animation-delay: 0.15s; }
      .main-inner > *:nth-child(5) { animation-delay: 0.2s; }

      /* ===== COPY BUTTON (CSS only, JS not needed) ===== */
      .code-block-wrapper {
        position: relative;
        margin-bottom: 24px;
      }

      .copy-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        padding: 4px 10px;
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--text-muted);
        font-size: 0.7rem;
        font-family: var(--font-mono);
        cursor: pointer;
        opacity: 0;
        transition: all 0.2s;
        z-index: 2;
      }

      .code-block-wrapper:hover .copy-btn { opacity: 1; }
      .copy-btn:hover { background: var(--fuego-bg); color: var(--fuego-light); border-color: var(--fuego); }

      /* ===== STEP NUMBERS ===== */
      .step-list {
        counter-reset: step;
        list-style: none;
        padding: 0;
      }

      .step-list li {
        counter-increment: step;
        padding: 16px 20px 16px 56px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: 10px;
        position: relative;
        font-size: 0.95rem;
        color: var(--text-dim);
        transition: all 0.2s;
      }

      .step-list li:hover {
        border-color: var(--border-glow);
        background: var(--bg-hover);
      }

      .step-list li::before {
        content: counter(step);
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        width: 28px;
        height: 28px;
        background: linear-gradient(135deg, var(--fuego), var(--fuego-dark));
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 700;
        color: #fff;
        font-family: var(--font-mono);
      }

      .step-list li strong { color: var(--text); }

      /* ===== COLLAPSIBLE (details/summary) ===== */
      details {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        margin-bottom: 24px;
        overflow: hidden;
        transition: border-color 0.2s;
      }
      details:hover { border-color: var(--border-glow); }

      summary {
        padding: 14px 20px;
        cursor: pointer;
        font-weight: 500;
        color: var(--text);
        font-size: 0.9rem;
        user-select: none;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
      }
      summary:hover { background: var(--bg-hover); }
      summary::marker { color: var(--fuego); }
      summary::-webkit-details-marker { color: var(--fuego); }

      details[open] summary {
        border-bottom: 1px solid var(--border);
        background: var(--bg-hover);
      }

      details > *:not(summary) {
        padding: 16px 20px;
      }

      details table { margin: 0; }
      details .code-block-wrapper { margin: 0; }
    </style>
  </head>
  <body>
    <aside class="sidebar">
      <div class="sidebar-header">
        <a href="/docs/" class="logo">
          <div class="logo-icon">⎔</div>
          <span class="logo-text">Forja</span>
        </a>
        <div class="logo-sub">Lenguaje en español</div>
      </div>
      <nav class="sidebar-nav">
        <div class="section-title">Introducción</div>
        <a href="/docs/">¿Qué es Forja?</a>
        <a href="/docs/playground">Playground</a>
        <a href="/docs/instalacion">Instalación</a>
        <a href="/docs/uso">Uso (CLI)</a>

        <div class="section-title">Guía del Lenguaje</div>
        <a href="/docs/sintaxis/variables" class="sub"><span class="nav-dot"></span>Variables y constantes</a>
        <a href="/docs/sintaxis/tipos" class="sub"><span class="nav-dot"></span>Tipos de datos</a>
        <a href="/docs/sintaxis/funciones" class="sub"><span class="nav-dot"></span>Funciones</a>
        <a href="/docs/sintaxis/condicionales" class="sub"><span class="nav-dot"></span>Condicionales</a>
        <a href="/docs/sintaxis/bucles" class="sub"><span class="nav-dot"></span>Bucles</a>
        <a href="/docs/sintaxis/clases" class="sub"><span class="nav-dot"></span>Clases y POO</a>
        <a href="/docs/sintaxis/ownership" class="sub"><span class="nav-dot"></span>Ownership</a>
        <a href="/docs/sintaxis/operadores" class="sub"><span class="nav-dot"></span>Operadores</a>
        <a href="/docs/sintaxis/entrada" class="sub"><span class="nav-dot"></span>Entrada de usuario</a>
        <a href="/docs/sintaxis/coincidir" class="sub"><span class="nav-dot"></span>Pattern matching</a>
        <a href="/docs/sintaxis/enums" class="sub"><span class="nav-dot"></span>Tipos algebraicos</a>
        <a href="/docs/sintaxis/traits" class="sub"><span class="nav-dot"></span>Traits / Interfaces</a>
        <a href="/docs/sintaxis/gui" class="sub"><span class="nav-dot"></span>GUI nativa (Xilem)</a>
        <a href="/docs/sintaxis/concurrencia" class="sub"><span class="nav-dot"></span>Concurrencia</a>
