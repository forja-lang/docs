    <main class="main">
      <div class="main-inner">
        <slot />
      </div>
      </main>
<script>
(() => {
  const sidebarLinks = document.querySelectorAll('.sidebar-nav a');
  const mainInner = document.querySelector('.main-inner');

  function setActive(link) {
    sidebarLinks.forEach(l => l.classList.remove('active'));
    link.classList.add('active');
  }

  async function loadPage(url, pushState = true) {
    try {
      const res = await fetch(url);
      const html = await res.text();
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      const newContent = doc.querySelector('.main-inner');
      if (newContent && mainInner) {
        mainInner.innerHTML = newContent.innerHTML;
      }
      // Actualizar título de la página
      const newTitle = doc.querySelector('title');
      if (newTitle) document.title = newTitle.textContent;
      // Marcar link activo
      const newLink = Array.from(sidebarLinks).find(l => l.getAttribute('href') === url);
      if (newLink) setActive(newLink);
      if (pushState) history.pushState(null, '', url);
    } catch (e) {
      console.error('Navigation error', e);
    }
  }

  sidebarLinks.forEach(link => {
  const href = link.getAttribute('href');
  if (!href || !href.startsWith('/docs/')) return;
  link.addEventListener('click', e => {
    e.preventDefault();
    loadPage(href);
  });
});

  window.addEventListener('popstate', () => {
    loadPage(location.pathname, false);
  });

  /** Determina el link activo comparando el path actual contra los href del menú.
   *  Con base='/docs', los href se transforman a /docs/... en el build */
  let bestMatch = null;
  let bestLen = 0;
  const currentPath = location.pathname.replace(/\/+$/, '');
  sidebarLinks.forEach(link => {
    const href = link.getAttribute('href');
    if (!href) return;
    const hrefClean = href.replace(/\/+$/, '');
    // Coincidencia exacta o el menú que sea prefijo del path actual
    if (hrefClean === currentPath) {
      bestMatch = link;
      bestLen = hrefClean.length;
    } else if (hrefClean.length > bestLen && currentPath.startsWith(hrefClean)) {
      bestMatch = link;
      bestLen = hrefClean.length;
    }
  });
  if (bestMatch) setActive(bestMatch);
})();
</script>
  </body>
</html>
